# Contoh file .env.local untuk development
# Jangan commit file ini ke repo

# Connection string ke Neon / PostgreSQL
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Jika Neon memerlukan SSL, set true. Biasanya autodetect sudah aktif.
DATABASE_SSL=true

# JWT secret minimal 32 chars
JWT_SECRET=verylongrandomsecretvalue_min_32_chars

# Gmail (untuk OTP) - gunakan App Password jika 2FA aktif
GMAIL_USER=youremail@gmail.com
GMAIL_PASS=your_gmail_app_password

# Base URL (untuk email links, dll.)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Opsional: set ke 'production' di hosting
NODE_ENV=development
